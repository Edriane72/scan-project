<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SCAN Spam Call Mitigation"
            android:textAppearance="?android:attr/textAppearanceLarge"
            android:textStyle="bold"
            android:paddingBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Caller Number"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editCallerNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter incoming caller number"
            android:inputType="phone"
            android:paddingBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CNAM (optional)"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editCnam"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Caller name or label"
            android:inputType="textPersonName"
            android:paddingBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Timestamp (epoch ms, optional)"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editTimestamp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Leave blank to use current time"
            android:inputType="number"
            android:paddingBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp">

            <TextView
                android:id="@+id/textHudStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="HUD: Enabled"
                android:textColor="#FF000000"
                android:textStyle="bold" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchHudToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enable Call HUD" />
        </LinearLayout>

        <Button
            android:id="@+id/buttonSimulate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Simulate Call"
            android:padding="12dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#FF888888"
            android:layout_marginVertical="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Verdict"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textVerdict"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No simulation run yet"
            android:textColor="#FF000000"
            android:paddingBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Details"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:paddingBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Audit Log"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No logs yet"
            android:paddingBottom="24dp" />

    </LinearLayout>
</ScrollView>
